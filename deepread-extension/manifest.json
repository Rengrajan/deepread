{
  "manifest_version": 3,
  "name": "DeepRead",
  "version": "1.2",
  "description": "Select any text on any webpage or PDF — ask your local Ollama model. Go as deep as you want.",

  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "32": "icons/icon.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "reader/reader.html",
        "reader/reader.js",
        "notes/notes.html",
        "notes/notes.js",
        "lib/pdf.min.js",
        "lib/pdf.worker.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "32": "icons/icon.png"
  }
}
